{
  "name": "@iruka-edu/mini-game-sdk",
  "version": "0.6.0",
  "description": "Iruka Mini Game SDK (Hub bridge, telemetry, runtime lifecycle)",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
