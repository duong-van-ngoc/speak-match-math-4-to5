    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@iruka-edu/game-core": "^0.3.0",
    "howler": "^2.2.4"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/howler": "^2.2.12",
    "phaser": "^3.80.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "test": "node -e \"console.log('sdk: no tests yet')\""
