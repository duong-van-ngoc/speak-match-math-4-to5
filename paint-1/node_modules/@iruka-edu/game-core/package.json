{
  "name": "@iruka-edu/game-core",
  "version": "0.3.0",
  "description": "Core bridge & contracts for Iruka Game Hub (iFrame-only)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "phaser": "^3.80.0",
    "rimraf": "^5",
    "tsup": "^8",
    "typescript": "^5"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iruka-edu/iruka-mini-game-sdk.git"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}