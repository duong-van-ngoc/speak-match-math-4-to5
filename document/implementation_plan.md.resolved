│   ├── scenes/
│   │   ├── end/
│   │   │   └── EndScene.ts
│   │   ├── speak/                   # ← Scene chính
│   │   │   └── CountTrainScene.ts
│   │   ├── index.ts
│   │   ├── BootScene.ts
│   │   ├── PreloadScene.ts
│   │   └── SceneBase.ts
│   ├── utils/
